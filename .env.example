# WhatsApp Cloud API Credentials
# Obtenha essas valores em: https://developers.facebook.com/

# ID do número telefônico (encontre em WhatsApp Business → Settings)
WHATSAPP_PHONE_NUMBER_ID=123456789

# ID da conta business (encontre em Meta for Developers → Settings)
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789

# Token de acesso (gere em App Roles → Token com permissões whatsapp_business_messaging)
WHATSAPP_ACCESS_TOKEN=EAAIxxx...

# Token para validar webhooks (escolha um valor aleatório, use mesmo valor no Meta for Developers)
WHATSAPP_WEBHOOK_TOKEN=meu-token-secreto-seguro-123

# Namespace desta instância – usado como prefixo nas chaves Redis e arquivos /tmp
# Mude se você rodar múltiplas instâncias com o mesmo Redis (ex: waclientmedidor)
APP_NAMESPACE=waclient

# Google Sheets – credenciais da conta de serviço
GOOGLE_SHEET_ID=sua-spreadsheet-id-aqui
GOOGLE_SHEETS_CLIENT_EMAIL=sua-conta-servico@projeto.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Nomes das abas do Google Sheets – bot de militância (padrões abaixo; altere se necessário)
GOOGLE_MILITANTES_SHEET_NAME=Militantes
GOOGLE_MISSOES_SHEET_NAME=Missões
GOOGLE_CONTEUDOS_SHEET_NAME=Conteúdos
GOOGLE_EVENTOS_SHEET_NAME=Eventos
GOOGLE_LIDERANCA_SHEET_NAME=Liderança
GOOGLE_DENUNCIAS_SHEET_NAME=Denúncias

# Conteúdo dinâmico do bot (atualize sem precisar fazer redeploy)
# Missão do dia – descreva a tarefa que os militantes devem cumprir hoje
MISSAO_DO_DIA=Hoje publicamos um novo vídeo no YouTube.\n\nPassos:\n1️⃣ Assistir até o final\n2️⃣ Curtir o vídeo\n3️⃣ Fazer um comentário\n4️⃣ Compartilhar com 3 pessoas

# Próximos eventos – liste os eventos presenciais ou digitais
PROXIMOS_EVENTOS=Sábado – Reunião da Militância\nLocal: Centro\nHorário: 19h\n\nDomingo – Ação Comunitária\nLocal: Messejana\nHorário: 8h

# Novo conteúdo – descreva o conteúdo mais recente a divulgar
NOVO_CONTEUDO=Novo vídeo no YouTube: "Como melhorar a saúde pública"\nAssista: https://youtube.com/watch?v=exemplo

# Tipo do conteúdo: vídeo, post, live, artigo
NOVO_CONTEUDO_TIPO=vídeo

