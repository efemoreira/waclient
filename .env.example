# WhatsApp Cloud API Credentials
# Obtenha essas valores em: https://developers.facebook.com/

# ID do número telefônico (encontre em WhatsApp Business → Settings)
WHATSAPP_PHONE_NUMBER_ID=123456789

# ID da conta business (encontre em Meta for Developers → Settings)
WHATSAPP_BUSINESS_ACCOUNT_ID=123456789

# Token de acesso (gere em App Roles → Token com permissões whatsapp_business_messaging)
WHATSAPP_ACCESS_TOKEN=EAAIxxx...

# Token para validar webhooks (escolha um valor aleatório, use mesmo valor no Meta for Developers)
WHATSAPP_WEBHOOK_TOKEN=meu-token-secreto-seguro-123

# Google Sheets – credenciais da conta de serviço
GOOGLE_SHEET_ID=sua-spreadsheet-id-aqui
GOOGLE_SHEETS_CLIENT_EMAIL=sua-conta-servico@projeto.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# Ollama – LLM local para respostas em linguagem natural
# Quando configurado, o bot usa o Ollama para responder mensagens que não correspondem
# a nenhum comando conhecido (fallback de linguagem natural).
# Deixe OLLAMA_BASE_URL vazio para desabilitar essa funcionalidade.
#
# Instale o Ollama em: https://ollama.com
# Após instalar, execute: ollama pull llama3  (ou outro modelo de sua escolha)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# OLLAMA_TEMPERATURE=0.7         # Criatividade (0=determinístico, 1=criativo). Padrão: 0.7
# OLLAMA_MAX_TOKENS=512           # Tamanho máximo da resposta. Padrão: 512
# OLLAMA_TIMEOUT_MS=30000         # Timeout em ms. Padrão: 30000
# OLLAMA_SYSTEM_PROMPT=           # Prompt de sistema customizado (opcional)

# Nomes das abas do Google Sheets (padrões abaixo; altere se necessário)
# Aba de log detalhado de leituras – retenção automática de 90 dias
GOOGLE_LEITURAS_SHEET_NAME=leituras
# Aba de acumulado semanal por Id + Tipo (reset individual por período)
GOOGLE_ACUMULADO_SEMANA_SHEET_NAME=acumulado_semana
# Aba de acumulado mensal por Id + Tipo (reset individual por período)
GOOGLE_ACUMULADO_MES_SHEET_NAME=acumulado_mes
# Aba de histórico consolidado – nunca apagado
GOOGLE_HISTORICO_RESUMO_SHEET_NAME=historico_resumo

