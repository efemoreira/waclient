{
  "name": "waclient",
  "version": "1.0.0",
  "description": "WhatsApp Business API Client for Node.js",
  "scripts": {
    "build": "tsc && cp -r public/* dist/",
    "dev": "vercel dev",
    "deploy": "vercel --prod",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.0",
    "@vercel/node": "^4.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@upstash/redis": "^1.36.2",
    "axios": "^1.13.4",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.2.3",
    "googleapis": "171.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "moduleNameMapper": {
      "militanciaSheet$": "<rootDir>/tests/__mocks__/militanciaSheet.ts"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": {
          "strict": true,
          "esModuleInterop": true,
          "module": "commonjs",
          "target": "ES2020",
          "rootDir": ".",
          "baseUrl": "."
        }
      }]
    }
  }
}
